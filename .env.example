# ──────────────────────────────────────────────────
# Eth-Links Environment Variables
# Copy this file to .env.local and fill in real values
# ──────────────────────────────────────────────────

# Supabase — Required
NEXT_PUBLIC_SUPABASE_URL=changeme
NEXT_PUBLIC_SUPABASE_ANON_KEY=changeme
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=changeme
SUPABASE_SERVICE_ROLE_KEY=changeme

# Application
ADMIN_EMAIL=changeme
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google AI (Gemini)
GOOGLE_API_KEY=changeme
GEMINI_MODEL_VERSION=gemini-pro
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048
AI_TOP_P=0.9
AI_TOP_K=40

# Payment Gateway (Chapa)
CHAPA_SECRET_KEY=changeme
CHAPA_WEBHOOK_SECRET=changeme

# Payment Gateway (Telebirr / CBE — webhook HMAC secrets)
TELEBIRR_PUBLIC_KEY=changeme
CBE_BIRR_SECRET=changeme

# Upstash Redis — distributed rate limiting (production recommended)
# Falls back to in-memory rate limiting when not set
UPSTASH_REDIS_REST_URL=changeme
UPSTASH_REDIS_REST_TOKEN=changeme

# Sentry — error monitoring (optional)
SENTRY_DSN=changeme
SENTRY_ORG=changeme
SENTRY_PROJECT=changeme
