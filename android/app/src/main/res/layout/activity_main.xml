<?xml version="1.0" encoding="utf-8"?>
<!--
    Root activity layout for Capacitor WebView.
    Both the CoordinatorLayout and WebView have explicit dark backgrounds
    matching the app's "Midnight Gold" theme (#0B0C15) to prevent any white
    frame between the native splash screen dismissal and the web content paint.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splashBackground"
    tools:context=".MainActivity">

    <WebView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/splashBackground" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
