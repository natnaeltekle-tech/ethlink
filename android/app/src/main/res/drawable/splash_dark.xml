<?xml version="1.0" encoding="utf-8"?>
<!--
    Dark splash icon drawable.
    Renders as a circle matching the app's dark background (#0B0C15),
    making it invisible against windowSplashScreenBackground.
    This eliminates the white circle caused by the old white-background splash.png
    being used as windowSplashScreenAnimatedIcon on Android 12+.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#0B0C15" />
    <size
        android:width="108dp"
        android:height="108dp" />
</shape>
